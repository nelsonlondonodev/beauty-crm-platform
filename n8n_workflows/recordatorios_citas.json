{
  "name": "Recordatorios de Citas - Beauty CRM",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "name": "Cron (Cada 30 min)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        260,
        340
      ],
      "id": "cron-recordatorios"
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "appointments",
        "returnAll": true,
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "estado",
              "condition": "eq",
              "keyValue": "programada"
            }
          ]
        }
      },
      "name": "Supabase: Buscar Citas Próximas",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        480,
        340
      ],
      "id": "buscar-citas",
      "credentials": {
        "supabaseApi": {
          "id": "5hkYuZVAhznvx7lf",
          "name": "Supabase Fidelizacion Narbo's Pro"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 3
          },
          "conditions": [
            {
              "id": "cond-24h",
              "leftValue": "={{ (new Date($json.fecha_cita).getTime() - new Date().getTime()) / 36e5 }}",
              "rightValue": "24.5",
              "operator": {
                "type": "number",
                "operation": "smaller"
              }
            },
            {
              "id": "cond-24h-min",
              "leftValue": "={{ (new Date($json.fecha_cita).getTime() - new Date().getTime()) / 36e5 }}",
              "rightValue": "23",
              "operator": {
                "type": "number",
                "operation": "larger"
              }
            },
            {
              "id": "cond-not-sent",
              "leftValue": "={{ $json.reminder_24h_sent }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "name": "Filter: ¿Faltan 24h?",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.3,
      "position": [
        700,
        240
      ],
      "id": "filter-24h"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 3
          },
          "conditions": [
            {
              "id": "cond-2h",
              "leftValue": "={{ (new Date($json.fecha_cita).getTime() - new Date().getTime()) / 36e5 }}",
              "rightValue": "2.5",
              "operator": {
                "type": "number",
                "operation": "smaller"
              }
            },
            {
              "id": "cond-2h-min",
              "leftValue": "={{ (new Date($json.fecha_cita).getTime() - new Date().getTime()) / 36e5 }}",
              "rightValue": "1.5",
              "operator": {
                "type": "number",
                "operation": "larger"
              }
            },
            {
              "id": "cond-not-sent-2h",
              "leftValue": "={{ $json.reminder_2h_sent }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "name": "Filter: ¿Faltan 2h?",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.3,
      "position": [
        700,
        440
      ],
      "id": "filter-2h"
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "clientes_fidelizacion",
        "limit": 1,
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $json.client_id }}"
            }
          ]
        }
      },
      "name": "Supabase: Datos Cliente",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        1120,
        340
      ],
      "id": "datos-cliente",
