# ── Supabase ───────────────────────────────────────────────────────────────
# URL y clave anónima del proyecto Supabase del cliente.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Integraciones ──────────────────────────────────────────────────────────
# URL del webhook de n8n para notificaciones de citas.
# Dejar vacío si n8n no está configurado (las notificaciones se desactivarán).
VITE_N8N_WEBHOOK_URL=
