# =============================================
# Variables de Entorno - Londy CRM
# Copia este archivo como .env.development o .env.production
# y rellena con los valores reales.
# =============================================

# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# n8n Webhook
VITE_N8N_WEBHOOK_URL=https://tu-n8n-server/webhook/nueva-cita

# Twilio (Opcional)
VITE_TWILIO_ACCOUNT_SID=tu-sid
VITE_TWILIO_AUTH_TOKEN=tu-token
VITE_TWILIO_PHONE_NUMBER=+1234567890
